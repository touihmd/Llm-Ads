<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#080C14; --card:#111827; --card2:#141C2E;
  --gold:#D4A853; --gold2:#F0C060; --goldglow:rgba(212,168,83,0.15);
  --en:#34D399; --fr:#60A5FA; --muted:#6B7280; --dim:#374151;
  --text:#E5E7EB; --white:#F9FAFB; --border:rgba(255,255,255,0.07);
  --bordergold:rgba(212,168,83,0.3);
}
body{
  background:var(--ink); min-height:100vh; font-family:'Inter',sans-serif;
  color:var(--text); padding:0 0 80px;
  background-image:radial-gradient(ellipse 80% 50% at 50% -10%,rgba(212,168,83,0.08) 0%,transparent 70%);
}
.hero{ text-align:center; padding:64px 24px 48px; position:relative; }
.hero::after{ content:''; position:absolute; bottom:0; left:50%; transform:translateX(-50%);
  width:120px;height:1px; background:linear-gradient(90deg,transparent,var(--gold),transparent); }
.hero-label{ font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:4px; text-transform:uppercase;
  color:var(--gold); margin-bottom:20px; display:block; opacity:0.8; }
.hero h1{ font-family:'Syne',sans-serif; font-size:clamp(32px,6vw,56px); font-weight:800;
  color:var(--white); line-height:1.1; margin-bottom:16px; letter-spacing:-1px; }
.hero h1 em{ color:var(--gold); font-style:normal; background:linear-gradient(135deg,var(--gold),var(--gold2));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
.hero-sub{ font-size:15px; color:var(--muted); font-weight:300; max-width:480px; margin:0 auto; line-height:1.6; }
.lang-pills{ display:flex; gap:10px; justify-content:center; margin-top:24px; flex-wrap:wrap; }
.lang-pill{ padding:6px 16px; border-radius:50px; font-size:12px; font-weight:600; letter-spacing:1px;
  border:1px solid; font-family:'JetBrains Mono',monospace; }
.lang-pill.fr{border-color:var(--fr);color:var(--fr);background:rgba(96,165,250,0.08);}
.lang-pill.en{border-color:var(--en);color:var(--en);background:rgba(52,211,153,0.08);}

.grid{ max-width:920px; margin:56px auto 0; padding:0 20px; display:flex; flex-direction:column; gap:40px; }

.tcard{ background:var(--card); border:1px solid var(--border); border-radius:24px; overflow:hidden;
  transition:border-color .3s,box-shadow .3s; position:relative; }
.tcard::before{ content:''; position:absolute; top:0; left:0; right:0; height:2px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent); opacity:0; transition:opacity .3s; }
.tcard:hover{ border-color:var(--bordergold); box-shadow:0 0 60px rgba(212,168,83,0.07); }
.tcard:hover::before{opacity:1;}

.tcard-top{ display:flex; align-items:center; padding:20px 24px 16px; gap:12px; border-bottom:1px solid var(--border); }
.post-num{ font-family:'Syne',sans-serif; font-size:13px;font-weight:800;color:var(--ink);background:var(--gold);
  width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0; }
.post-theme{ font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:var(--muted);}
.x-logo{ margin-left:auto;width:20px;height:20px;opacity:0.2;flex-shrink:0; }

.lang-tabs{ display:flex; border-bottom:1px solid var(--border); }
.ltab{ flex:1; padding:13px 0; font-size:12px;font-weight:600;letter-spacing:2px;
  text-transform:uppercase; cursor:pointer; border:none; background:transparent; color:var(--muted);
  transition:all .2s; font-family:'JetBrains Mono',monospace; position:relative; }
.ltab::after{ content:''; position:absolute; bottom:0; left:12px; right:12px; height:2px; border-radius:2px 2px 0 0; transform:scaleX(0); transition:transform .25s; }
.ltab.fr{color:var(--fr);} .ltab.fr::after{background:var(--fr);}
.ltab.en{color:var(--en);} .ltab.en::after{background:var(--en);}
.ltab.active::after{transform:scaleX(1);}
.ltab:not(.active){color:var(--dim);}

.panels{position:relative;}
.panel{display:none;padding:28px 24px 0;}
.panel.active{display:block;}

.tweet-body{ font-size:16px;line-height:1.85;color:var(--white); font-weight:400; white-space:pre-wrap; margin-bottom:24px; font-family:'Inter',sans-serif;}
.tweet-body strong,.tweet-body b{ color:var(--gold2); font-weight:600; }
.tweet-body .tag{color:var(--fr); font-weight:500;}
.tweet-body .mention{color:var(--en); font-weight:500;}

.card-footer{ padding:0 24px 24px; display:flex;align-items:center;justify-content:space-between; flex-wrap:wrap; }
.char-info{ font-family:'JetBrains Mono',monospace; font-size:11px;color:var(--dim); }
.cbtn{ display:flex;align-items:center;gap:7px; padding:9px 20px;border-radius:50px; font-size:12px;font-weight:600;letter-spacing:.5px;
  cursor:pointer;border:1px solid; transition:all .2s;font-family:'Inter',sans-serif; user-select:none; }
.cbtn:hover{transform:translateY(-2px); filter:brightness(1.15);}
.cbtn:active{transform:translateY(0);}
.cbtn.fr{border-color:var(--fr);color:var(--fr);background:rgba(96,165,250,0.08);}
.cbtn.en{border-color:var(--en);color:var(--en);background:rgba(52,211,153,0.08);}
.cbtn.done{opacity:.5;pointer-events:none;}

.footer-bar{ max-width:920px;margin:56px auto 0;padding:0 20px;}
.footer-inner{ border:1px dashed var(--bordergold); border-radius:20px; padding:28px 32px; display:flex;align-items:center;justify-content:space-between; gap:20px; flex-wrap:wrap;}
.footer-text{ font-size:14px;color:var(--muted); line-height:1.6;}
.footer-text strong{color:var(--gold);}
.copy-all-row{display:flex;gap:10px;flex-wrap:wrap;}
.copy-all-btn{ padding:10px 22px; border-radius:50px; border:1px solid var(--bordergold); background:var(--goldglow); color:var(--gold);
  font-size:13px;font-weight:600; cursor:pointer;transition:all .2s;font-family:'Inter',sans-serif;}
.copy-all-btn:hover{background:rgba(212,168,83,0.25); transform:translateY(-1px);}

.toast{ position:fixed; bottom:32px; right:32px; background:var(--card2); border:1px solid var(--bordergold);
  color:var(--gold); padding:12px 24px; border-radius:12px; font-size:14px;font-weight:500;
  opacity:0; transform:translateY(12px); transition:all .3s; pointer-events:none; z-index:9999;font-family:'Inter',sans-serif;
  box-shadow:0 8px 32px rgba(0,0,0,0.4); }
.toast.show{opacity:1;transform:translateY(0);}
</style>
</head>
