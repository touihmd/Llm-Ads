function renderText(txt){ return txt.replace(/\*\*(.+?)\*\*/g,'<b>$1</b>').replace(/<b>(.+?)<\/b>/g,'<b>$1</b>').replace(/(#\w+)/g,'<span class="tag">$1</span>').replace(/(@\w+)/g,'<span class="mention">$1</span>');}
function cleanText(txt){ return txt.replace(/<b>(.+?)<\/b>/g,'$1').replace(/<[^>]+>/g,''); }
function countChars(txt){ return cleanText(txt).replace(/\n/g,'↵').length; }

